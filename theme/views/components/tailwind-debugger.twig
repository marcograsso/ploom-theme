<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('tailwindDebugger', () => ({
            width: window.innerWidth,
            height: window.innerHeight,
            showNotification: false,

            trigger: {
                async ["@click"]() {
                    const currentBreakpoint = Array.from(this.$el.querySelectorAll('#breakpoint span')).filter(span => window.getComputedStyle(span).display === 'inline')[0].textContent;
                    await navigator.clipboard.writeText(currentBreakpoint);
                    this.showNotification = true;
                    console.log(currentBreakpoint);
                    setTimeout(() => this.showNotification = false, 500);
                }
            }
        }))
    })
</script>
<div x-data="tailwindDebugger()"
     @resize.window="width = window.innerWidth; height = window.innerHeight"
     x-bind="trigger"
     class="fixed bottom-5 left-5 z-50 flex items-center space-x-2 rounded-full bg-black px-2.5 py-1 font-mono text-xs font-medium text-white uppercase border border-white/10 cursor-pointer overflow-hidden">
    <div id="notification"
         x-show="showNotification"
         x-transition
         class="absolute inset-0 flex items-center justify-center text-black bg-white">
        Copied!
    </div>
    <div id="breakpoint"
         class="w-[3ch] text-right">
        <span class="sm:hidden">--</span>
        <span class="hidden sm:inline md:hidden">sm</span>
        <span class="hidden md:inline lg:hidden">md</span>
        <span class="hidden lg:inline xl:hidden">lg</span>
        <span class="hidden xl:inline 2xl:hidden">xl</span>
        <span class="hidden 2xl:inline">2xl</span>
    </div>
    <div class="w-px h-4 bg-gray-800">
    </div>
    <div class="flex">
        <div class="w-[4ch] text-right">
            <span x-text="width">0</span>
        </div>
        <span class="mx-[1ch]">×</span>
        <div class="w-[4ch] text-left">
            <span x-text="height">0</span>
        </div>
    </div>
</div>
