{% apply mjml_to_html %}
<mjml>
  <mj-head>
    <mj-font name="Inter" href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900" />
    {% block head %}{% endblock %}
    <mj-attributes>
      <mj-text font-size="16px" line-height="1.2" />
      <mj-all font-family="Inter, ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'" />
    </mj-attributes>
  </mj-head>

  <mj-body background-color="white">
    <mj-section>
      <mj-column>
       {% block content %}{% endblock content %}
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
{% endapply %}