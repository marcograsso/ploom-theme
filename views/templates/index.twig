{% extends "base.twig" %}

{% block content %}
  <h2>{{ foo }}</h2>
  {% for post in posts %}
    {% include ["parts/tease-" ~ post.type ~ ".twig", "parts/tease.twig"] %}
  {% endfor %}

  {% include "parts/pagination.twig" with {
    pagination: posts.pagination({ show_all: false, mid_size: 3, end_size: 2 })
  } %}
{% endblock content %}
