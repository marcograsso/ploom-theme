<!DOCTYPE html>
<html {{ site.language_attributes }}>
  {% block head %}
    {{ include("parts/head.twig") }}
  {% endblock head %}
  <body {{ attr({ class: [body_class, "antialiased"] }) }}>
    {{ function("wp_body_open") }}

    {% if environment == "development" %}
      {{ include("components/tailwind-debugger.twig") }}
    {% endif %}
    {% block navbar %}
      {{ include("components/navigation/navbar.twig") }}
    {% endblock navbar %}
    <main>
      {% block content %}

      {% endblock content %}
    </main>

    {% block footer %}
      {{ include("components/navigation/footer.twig") }}
      <div
        class="main-container fixed! bottom-0! h-fit w-full backdrop-blur-xl"
      >
        <span
          class="font-base container block p-1 text-center text-xs leading-[125%] font-light"
        >
          Prodotto solo per 18+. Non privo di rischi. Previsto uso con sticks
          contenenti nicotina, sostanza che crea dipendenza.
        </span>
      </div>
    {% endblock footer %}

    {{ function("wp_footer") }}
    {% do action("get_footer", null) %}
  </body>
</html>
