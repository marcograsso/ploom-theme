{
  "name": "wp-starter-vite",
  "author": "Yaser Ahmady",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "jaq -i '.vite.environment = \"development\"' config.json && cross-env NODE_ENV=development vite",
    "watch": "npm run dev",
    "build": "vite build && jaq -i '.vite.environment = \"production\"' config.json",
    "clean": "rm -rf node_modules",
    "zip": "python build-theme.py"
  },
  "dependencies": {
    "gsap": "^3.13.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/vite": "^4.1.11",
    "alpinejs": "^3.14.9",
    "swiper": "^11.2.10",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.24.0",
    "@zackad/prettier-plugin-twig": "^0.16.0",
    "cross-env": "^7.0.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "vite": "^7.0.5",
    "vite-plugin-dev-manifest": "^1.4.1",
    "vite-plugin-mkcert": "^1.17.8"
  }
}
