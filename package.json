{
  "name": "wp-starter-vite",
  "author": "Yaser Ahmady",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "jaq -i '.vite.environment = \"development\"' config.json && cross-env NODE_ENV=development vite",
    "watch": "npm run dev",
    "build": "vite build && jaq -i '.vite.environment = \"production\"' config.json",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.17",
    "alpinejs": "^3.15.2",
    "gsap": "^3.14.1",
    "non.geist": "^2.0.1",
    "swiper": "^12.0.3",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.24.0",
    "@zackad/prettier-plugin-twig": "^0.16.0",
    "cross-env": "^10.1.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vite": "^7.2.7",
    "vite-plugin-dev-manifest": "^1.4.1",
    "vite-plugin-mkcert": "^1.17.9"
  }
}
