{
  "name": "wp-starter-vite",
  "author": "Yaser Ahmady",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "jaq -i '.vite.environment = \"development\"' config.json && cross-env NODE_ENV=development vite && npm run build",
    "watch": "npm run dev",
    "build": "vite build && jaq -i '.vite.environment = \"production\"' config.json && npm run svgo",
    "clean": "rm -rf node_modules",
    "svgo": "svgo --config=svgo.config.mjs -rf ./views/icons/ -o ./views/icons/"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.8",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "alpinejs": "^3.15.8",
    "gsap": "^3.14.2",
    "mapbox-gl": "^3.20.0",
    "non.geist": "^2.0.1",
    "swiper": "^12.1.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.24.0",
    "@zackad/prettier-plugin-twig": "^0.16.3",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svgo": "^4.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dev-manifest": "^1.4.1",
    "vite-plugin-mkcert": "^1.17.9"
  }
}
