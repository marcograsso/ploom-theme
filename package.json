{
  "name": "wp-starter-vite",
  "author": "Yaser Ahmady",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "preinstall": "git config core.hooksPath scripts",
    "dev": "jaq -i '.vite.environment = \"development\"' config.json && cross-env NODE_ENV=development vite",
    "watch": "npm run dev",
    "build": "vite build && jaq -i '.vite.environment = \"production\"' config.json",
    "clean": "rm -rf node_modules",
    "zip": "python build-theme.py"
  },
  "dependencies": {
    "alpinejs": "^3.14.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "gsap": "^3.12.5",
    "postcss": "^8.4.47",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.13",
    "@tailwindcss/forms": "^0.5.9"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.22.4",
    "@zackad/prettier-plugin-twig": "^0.16.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prettier": "^3.5.3",
    "vite": "^6.2.2"
  }
}
